{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "blocks"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos"
      ]
    },
    "start_date": {
      "type": "datetime"
    },
    "end_date": {
      "type": "datetime"
    },
    "talks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::talk.talk",
      "mappedBy": "event"
    },
    "location": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::location.location",
      "inversedBy": "events"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "events"
    },
    "communities": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::community.community",
      "mappedBy": "events"
    },
    "agenda": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::agenda.agenda",
      "mappedBy": "event"
    },
    "comments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::comment.comment",
      "mappedBy": "event"
    },
    "subscription_link": {
      "type": "string"
    },
    "slug": {
      "type": "string",
      "required": false,
      "unique": true,
      "regex": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "deleted_at": {
      "type": "datetime"
    },
    "participants": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::participant.participant",
      "mappedBy": "event"
    },
    "is_online": {
      "type": "boolean",
      "default": false
    },
    "call_link": {
      "type": "string"
    },
    "teams": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::team.team",
      "mappedBy": "event"
    }
  }
}
