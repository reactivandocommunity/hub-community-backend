  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "identifier": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone_number": {
      "type": "string",
      "required": true
    },
    "event": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::event.event",
      "mappedBy": "participant"
    }
  }
}
